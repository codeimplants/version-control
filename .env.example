# ─────────────────────────────────────────────────────────────────────────────
# Nexus backend environment template. Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.
#
# Each deployed environment (dev / preprod / prod) is its OWN checkout on the
# VPS with its OWN `.env`. PM2 (ecosystem.config.js) sets NODE_ENV and PORT;
# dotenv does not override already-set vars, so PM2 wins and this file supplies
# the rest.
# ─────────────────────────────────────────────────────────────────────────────

# Which environment this process runs as:  dev | preprod | prod
# Also gates OTP behaviour (see TWOFACTOR_API_KEY below).
NODE_ENV=dev

# HTTP port. Convention on the VPS: prod=6000, dev=6001, preprod=6002.
PORT=6001

# ── Database (Neon PostgreSQL / Prisma) ──────────────────────────────────────
# ONE pair per checkout. Do NOT use DEV_/PREPROD_/PROD_ prefixes: Prisma reads
# these exact names and has no NODE_ENV switching, and the Prisma CLI
# (migrate/generate/studio) reads them too — so a prefixed setup risks the app
# using one database while migrations alter another.
#
# Isolation comes from each environment's own .env, not from variable names.
# Neon branch per environment:  production -> prod, dev -> dev, preprod -> preprod.
#
# DATABASE_URL = POOLED endpoint (host contains "-pooler") — application queries.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL = UNPOOLED endpoint (same host WITHOUT "-pooler") — migrations only.
# Prisma's advisory locks do not work through a pooler.
# REQUIRED — not optional. Prisma does not fall back to DATABASE_URL; if this is
# missing the schema fails to load entirely (error P1012).
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ── Switching databases locally ──────────────────────────────────────────────
# Keep exactly ONE pair active. To target another Neon branch, comment the
# current pair out and uncomment another, e.g.:
#
#   # --- dev branch ---
#   DATABASE_URL="...ep-dev-pooler..."
#   DIRECT_URL="...ep-dev..."
#
#   # --- preprod branch ---
#   # DATABASE_URL="...ep-preprod-pooler..."
#   # DIRECT_URL="...ep-preprod..."
#
# Whatever is ACTIVE here is what `prisma migrate deploy` will alter. Always
# check before migrating — this file is the only thing standing between a local
# command and the production database.

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret for signing admin JWTs.
JWT_SECRET=your_long_random_secret

# Admin console sign-in is phone + OTP. Set to "false" to disable the legacy
# email+password route (/auth/login) once every admin has a phone on record.
ALLOW_PASSWORD_LOGIN=true

# ── OTP (2Factor.in) ─────────────────────────────────────────────────────────
# When TWOFACTOR_API_KEY is unset (or NODE_ENV=dev) no SMS is sent and the OTP
# is returned in the response so the console can be exercised locally.
TWOFACTOR_API_KEY=your_2factor_api_key
# Key used to HMAC the OTP session (phone + sessionId + expiry). No OTP is stored.
HASH_KEY=your_secure_hash_key
